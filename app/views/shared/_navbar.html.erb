    <a href="<%= root_path %>" class="btn btn-ghost normal-case min-w-0 flex-1 justify-start gap-2 px-1 sm:px-2 h-auto py-2 text-primary-content hover:bg-primary-content/10">
      <%= image_tag "logo-white-bg.png", alt: "Zero Config Rails", width: 32, height: 32, class: "size-8 shrink-0 rounded-lg" %>
      <span class="truncate text-base sm:text-xl font-semibold">
        <span class="sm:hidden text-xs">Zero Config Rails</span>
        <span class="hidden sm:inline">Zero Config Rails <sup class="font-normal text-primary-content/70">Tools</sup></span>
      </span>
    </a>
  </div>

  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1 gap-1">
      <li>
        <a href="<%= root_path %>" class="text-primary-content hover:bg-primary-content/10 <%= "bg-primary-content/10" if current_page?(root_path) %>">Home</a>
      </li>
      <li>
        <details>
          <summary class="text-primary-content hover:bg-primary-content/10">Tools</summary>
          <ul class="z-[1] p-2 shadow-2xl bg-base-100 text-base-content border border-base-300/60 rounded-box w-72 max-h-[70vh] overflow-y-auto">
            <li>
              <a href="<%= app_rails_generators_path %>" class="flex flex-col items-start gap-0.5 py-3">
