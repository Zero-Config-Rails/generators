        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </label>
      <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-primary rounded-box w-64 max-h-[70vh] overflow-y-auto">
        <li><a href="<%= root_path %>" class="<%= current_page?(root_path) ? "active" : "" %>">Home</a></li>
        <li>
          <details>
            <summary>Tools</summary>
            <ul>
              <li><a href="<%= app_rails_generators_path %>">Rails App Generator</a></li>
              <% gem_installer_tools.each do |tool| %>
                <li><a href="<%= tool[:path] %>"><%= tool[:name] %></a></li>
              <% end %>
            </ul>
          </details>
        </li>
        <li><a href="<%= NavigationHelper::ZCR_SITE_URL %>/pricing">Pricing</a></li>
        <li><a href="<%= NavigationHelper::ZCR_APP_URL %>" class="btn btn-accent btn-sm mt-2">Dashboard</a></li>
      </ul>
