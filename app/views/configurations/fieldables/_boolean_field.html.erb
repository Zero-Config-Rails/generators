<% classes = class_names("toggle", { checked: field.default_value }) %>
<% flag_format = configuration_flag_format(configuration) %>

<fieldset class="fieldset">
  <div class="flex justify-between mb-1">
    <label class="label text-sm"><%= configuration_title(configuration) %></label>

    <% if configuration.description.present? %>
      <div class="tooltip tooltip-left tooltip-primary" data-tip="<%= configuration.description %>">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          class="stroke-neutral-content h-6 w-6 shrink-0">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>
    <% end %>
  </div>

  <input
    type="checkbox"
    class="<%= classes %>"
    <%= "checked" if field.default_value %>
    data-generator-command-configuration-id-value="<%= configuration.configuration_key %>"
    data-generator-command-flag-format-value="<%= flag_format %>"
    data-generator-command-negative-prefix-value="<%= configuration.try(:negative_prefix) %>"
    data-action="click->generator-command#update">
</fieldset>
